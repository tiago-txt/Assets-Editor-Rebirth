<Window x:Class="Assets_Editor.MigrateOutfitsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Migrate outfits (old server → Canary)"
        Width="520" Height="340" WindowStartupLocation="CenterOwner"
        Style="{StaticResource MaterialDesignWindow}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Old server (source)" Grid.Row="0" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Content="outfits.xml:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="OldOutfitsXmlPath" IsReadOnly="True" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <Button Content="Browse" Click="BrowseOldOutfits" Padding="8,2"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="Canary (output)" Grid.Row="1" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Label Content="outfits.xml:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="OutputOutfitsXmlPath" IsReadOnly="True" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <Button Content="Browse" Click="BrowseOutput" Padding="8,2"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <ProgressBar x:Name="ProgressBar" Width="180" Height="8" Minimum="0" Maximum="100" Value="0" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock x:Name="StatusText" Text="" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBox x:Name="LogText" Grid.Row="3" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" FontFamily="Consolas" FontSize="11"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="RunMigration" Content="Run migration" Click="RunMigration_Click" Style="{StaticResource MaterialDesignRaisedButton}" Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="Close" Click="Close_Click" Style="{StaticResource MaterialDesignFlatButton}" Padding="12,6"/>
        </StackPanel>
    </Grid>
</Window>
